MAMMOTION_EMAIL=your@email.com
MAMMOTION_PASSWORD=your-password
MAMMOTION_DEVICE_NAME=first
GO2RTC_PUBLISH_URL=rtsp://frigate:8554/mammotion_push
MAMMOTION_HEVC_MODE=copy
MAMMOTION_REFRESH_SECONDS=1800
MAMMOTION_RECONNECT_BACKOFF_SECONDS=8
MAMMOTION_STARTUP_FRAME_TIMEOUT_SECONDS=90
MAMMOTION_SOFT_STALL_TIMEOUT_SECONDS=12
MAMMOTION_KEYFRAME_REQUEST_COOLDOWN_SECONDS=8
MAMMOTION_FRAME_STALL_TIMEOUT_SECONDS=120
MAMMOTION_HEARTBEAT_FILE=/tmp/mammotion_heartbeat
